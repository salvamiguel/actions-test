{
  "name": "action-tester",
  "version": "1.0.0",
  "description": "Test GitHub Actions declaratively",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "test": "jest --testPathPattern=test/",
    "test:watch": "jest --testPathPattern=test/ --watch"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
